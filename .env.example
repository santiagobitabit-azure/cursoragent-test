# Servidor
PORT=8080
NODE_ENV=development

# Logging (Pino — JSON en producción, pretty en desarrollo)
# LOG_LEVEL=debug
# LOG_PRETTY=true

# PostgreSQL
# Local (docker compose):
# DATABASE_URL=postgresql://mundial:mundial@localhost:5432/mundial
# PGSSLMODE=disable

# Azure (usuario por defecto: mundialadmin, BD: mundial):
DATABASE_URL=postgresql://mundialadmin:TU_CONTRASEÑA@tu-servidor.postgres.database.azure.com:5432/mundial?sslmode=require

# JWT — en producción: openssl rand -base64 48
JWT_SECRET=change-me-in-production

# Microsoft Entra ID (inicio de sesión con cualquier cuenta Microsoft)
# Registrar app en Azure Portal → App registrations → redirect URI = http://localhost:8080
# AZURE_CLIENT_ID=tu-application-client-id
# AZURE_TENANT_ID=common

# API de resultados en vivo (worldcup26.ir)
WORLDCUP_API_BASE_URL=https://worldcup26.ir
LIVE_SYNC_ENABLED=true
LIVE_SYNC_WATCH_INTERVAL_MS=60000
LIVE_SYNC_LIVE_INTERVAL_MS=60000
LIVE_SYNC_MATCH_WINDOW_HOURS=2.5
